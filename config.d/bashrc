# ~/.bashrc

# ----- Only run for interactive shells -----
[[ $- != *i* ]] && return

# ----- History -----
HISTSIZE=5000
HISTFILESIZE=10000
HISTCONTROL=ignoredups:ignorespace
shopt -s histappend

__history_sync() {
  history -a
  history -n
}

if [[ -n "${PROMPT_COMMAND:-}" ]]; then
  PROMPT_COMMAND="__history_sync; $PROMPT_COMMAND"
else
  PROMPT_COMMAND="__history_sync"
fi

# ----- less / lesspipe -----
export PAGER="less"
export LESS="-QR"

if command -v lesspipe >/dev/null 2>&1; then
  eval "$(SHELL=/bin/sh lesspipe)"
elif [[ -x /usr/bin/lesspipe ]]; then
  eval "$(SHELL=/bin/sh /usr/bin/lesspipe)"
fi

# ----- Homebrew (Apple Silicon macOS) -----
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# ----- Bash completion -----
if ! shopt -oq posix; then
  if [[ -f /usr/share/bash-completion/bash_completion ]]; then
    . /usr/share/bash-completion/bash_completion
  elif [[ -f /etc/bash_completion ]]; then
    . /etc/bash_completion
  elif [[ -f /opt/homebrew/etc/profile.d/bash_completion.sh ]]; then
    . /opt/homebrew/etc/profile.d/bash_completion.sh
  fi
fi

# ----- PATH -----
export PATH="$HOME/bin:$PATH"

# ----- Environment -----
export EDITOR="vim"
export MOSH_ESCAPE_KEY='~'
export BASH_SILENCE_DEPRECATION_WARNING=1

# Optional / personal
export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
# export CLAUDE_CODE_VERSION_OVERRIDE=latest

# ----- Shell behavior -----
set -o vi
bind 'set bell-style visible'

# ----- Git prompt support -----
if [[ -f /usr/lib/git-core/git-sh-prompt ]]; then
  . /usr/lib/git-core/git-sh-prompt
elif [[ -f /usr/share/git/completion/git-prompt.sh ]]; then
  . /usr/share/git/completion/git-prompt.sh
elif [[ -f /opt/homebrew/etc/bash_completion.d/git-prompt.sh ]]; then
  . /opt/homebrew/etc/bash_completion.d/git-prompt.sh
fi

prompt_char() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 && printf '±' || printf '→'
}

# Let __git_ps1 show dirty state itself:
#   * = unstaged changes
#   + = staged changes
#   % = untracked files
#   $ = stashed changes
export GIT_PS1_SHOWDIRTYSTATE=1
export GIT_PS1_SHOWUNTRACKEDFILES=1
export GIT_PS1_SHOWSTASHSTATE=1

# ----- Prompt -----
if declare -F __git_ps1 >/dev/null 2>&1; then
  PS1='\[\e[0;34m\]\u\[\e[m\]@\[\e[0;31m\]\h\[\e[m\]:\[\e[0;36m\]\w\[\e[m\]$(__git_ps1 " (\[\e[0;31m\]%s\[\e[m\])") \n$(prompt_char) '
else
  PS1='\[\e[0;34m\]\u\[\e[m\]@\[\e[0;31m\]\h\[\e[m\]:\[\e[0;36m\]\w\[\e[m\] \n$(prompt_char) '
fi



# ----- USE CUSTOM SYSTEM  -----
# load the dot files directory from the .dotfiles file
if [ -f $HOME/.dotfiles_dir ]; then
  DOT_FILES=`cat $HOME/.dotfiles_dir`
else
  echo "NO .dotfiles_dir SPECIFYING THE DOTFILES DIRECTORY!\nExiting..."
  exit
fi

if [[ -f $DOT_FILES/bash/bash_aliases ]]; then
  . $DOT_FILES/bash/bash_aliases
fi

# project specific aliases. Not in repo
PROJECTS=$DOT_FILES/bash/projects/*
for f in $PROJECTS; do
  . $f
done

